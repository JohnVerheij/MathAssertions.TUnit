{
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "src/MathAssertions/MathAssertions.csproj",
            "src/MathAssertions.TUnit/MathAssertions.TUnit.csproj"
          ]
        }
      ],
      "dest": "api",
      "outputFormat": "mref",
      "memberLayout": "samePage",
      "includePrivateMembers": false,
      "disableGitFeatures": false,
      "filter": "filterConfig.yml"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["**/*.{md,yml}"],
        "exclude": ["_site/**", "obj/**"]
      }
    ],
    "resource": [
      {
        "files": ["CNAME", "robots.txt", "public/**"]
      }
    ],
    "output": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appName": "MathAssertions.TUnit",
      "_appTitle": "MathAssertions.TUnit",
      "_appFooter": "MIT. Copyright (c) 2026 John Verheij.",
      "_enableSearch": true,
      "_enableNewTab": true,
      "_disableContribution": true,
      "_disableBreadcrumb": true
    },
    "markdownEngineName": "markdig",
    "sitemap": {
      "baseUrl": "https://mathassertions.dev/",
      "priority": 0.5,
      "changefreq": "monthly"
    }
  }
}
